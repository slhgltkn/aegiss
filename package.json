{
  "name": "aegiss-token",
  "version": "2.0.0",
  "description": "Security-first, self-defending token library for Node.js. Powered by Rust, Ed25519, ChaCha20-Poly1305, CBOR, context binding. Zero JS dependencies.",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "napi": {
    "name": "aegiss",
    "triples": {
      "defaults": true,
      "additional": [
        "x86_64-unknown-linux-gnu",
        "aarch64-apple-darwin",
        "x86_64-pc-windows-msvc"
      ]
    }
  },
  "keywords": [
    "token",
    "jwt",
    "paseto",
    "ed25519",
    "blake3",
    "cbor",
    "security",
    "authentication",
    "context-binding",
    "zero-dependency",
    "rust"
  ],
  "author": "Salih Gultekin <me@salihgultek.in>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slhgltkn/aegiss.git"
  },
  "files": [
    "src",
    "artifacts",
    "README.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "napi build --platform --release ./artifacts",
    "build:debug": "napi build --platform ./artifacts",
    "universal": "napi universal",
    "version": "napi version"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4"
  },
  "optionalDependencies": {
    "aegiss-token-win32-x64-msvc": "2.0.0",
    "aegiss-token-darwin-x64": "2.0.0",
    "aegiss-token-linux-x64-gnu": "2.0.0",
    "aegiss-token-darwin-arm64": "2.0.0"
  }
}